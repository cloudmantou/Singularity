{
  "name": "singularity-obsidian-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "Obsidian plugin for the Singularity memory engine.",
  "scripts": {
    "build": "tsc --noEmit && esbuild src/main.ts --bundle --external:obsidian --format=cjs --target=es2018 --outfile=main.js",
    "dev": "esbuild src/main.ts --bundle --external:obsidian --format=cjs --target=es2018 --outfile=main.js --watch"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.28.1",
    "obsidian": "^1.8.7",
    "typescript": "^5.5.0"
  }
}
